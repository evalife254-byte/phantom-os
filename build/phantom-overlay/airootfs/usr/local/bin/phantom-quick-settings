#!/usr/bin/env python3
"""
Phantom Quick Settings - Quick Settings Panel for Phantom OS
A slide-out panel with common settings and toggles
"""

import gi
import os
import sys
import subprocess

gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, Gio, GLib, Gdk

class PhantomQuickSettings(Adw.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.set_title("Quick Settings")
        self.set_default_size(400, 600)
        self.set_resizable(False)
        
        # Set window to slide from right
        self.set_decorated(False)
        
        self.setup_ui()
        self.apply_css()
        
    def apply_css(self):
        """Apply Ghost Protocol theme"""
        css_provider = Gtk.CssProvider()
        css = """
        window {
            background-color: #141420;
            border-left: 2px solid #00F0FF;
            color: #E0E0E8;
        }
        
        .qs-container {
            background-color: #141420;
            padding: 20px;
        }
        
        .qs-header {
            color: #00F0FF;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 20px;
        }
        
        .qs-grid {
            margin: 10px 0;
        }
        
        .qs-tile {
            background-color: #1A1A2E;
            border-radius: 12px;
            border: 1px solid #1A1A2E;
            padding: 16px;
            margin: 4px;
        }
        
        .qs-tile:hover {
            background-color: rgba(0, 240, 255, 0.1);
            border-color: #00F0FF;
        }
        
        .qs-tile.active {
            background-color: rgba(0, 240, 255, 0.2);
            border-color: #00F0FF;
        }
        
        .qs-tile-icon {
            font-size: 24px;
            margin-bottom: 8px;
        }
        
        .qs-tile-label {
            font-size: 11px;
            color: #E0E0E8;
        }
        
        .qs-slider-box {
            background-color: #1A1A2E;
            border-radius: 12px;
            padding: 16px;
            margin: 8px 0;
        }
        
        .qs-slider-label {
            color: #6B6B80;
            font-size: 12px;
            margin-bottom: 8px;
        }
        
        scale trough {
            background-color: #0A0A0F;
            border-radius: 8px;
            min-height: 24px;
        }
        
        scale highlight {
            background-color: #00F0FF;
            border-radius: 8px;
        }
        
        scale slider {
            background-color: #E0E0E8;
            border-radius: 50%;
        }
        
        button.qs-action {
            background-color: #1A1A2E;
            color: #E0E0E8;
            border: 1px solid #00F0FF;
            border-radius: 8px;
            padding: 12px 24px;
            margin: 4px;
        }
        
        button.qs-action:hover {
            background-color: rgba(0, 240, 255, 0.15);
        }
        
        .qs-footer {
            border-top: 1px solid #1A1A2E;
            margin-top: 20px;
            padding-top: 20px;
        }
        """
        css_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
    
    def setup_ui(self):
        """Setup the quick settings UI"""
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_box.add_css_class('qs-container')
        self.set_content(main_box)
        
        # Header with close button
        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        header_box.set_margin_bottom(10)
        main_box.append(header_box)
        
        header_label = Gtk.Label(label="⚡ Quick Settings")
        header_label.add_css_class('qs-header')
        header_label.set_hexpand(True)
        header_label.set_xalign(0)
        header_box.append(header_label)
        
        close_btn = Gtk.Button(label="✕")
        close_btn.connect('clicked', lambda b: self.close())
        header_box.append(close_btn)
        
        # Quick toggles grid
        grid = Gtk.Grid()
        grid.add_css_class('qs-grid')
        grid.set_column_homogeneous(True)
        grid.set_row_homogeneous(True)
        grid.set_column_spacing(8)
        grid.set_row_spacing(8)
        main_box.append(grid)
        
        # Toggle buttons
        toggles = [
            ("wifi", "📶", "Wi-Fi", self.on_wifi_toggle),
            ("bluetooth", "🔵", "Bluetooth", self.on_bluetooth_toggle),
            ("airplane", "✈️", "Airplane", self.on_airplane_toggle),
            ("dnd", "🔕", "DND", self.on_dnd_toggle),
            ("flashlight", "🔦", "Flashlight", self.on_flashlight_toggle),
            ("rotation", "🔄", "Rotation", self.on_rotation_toggle),
            ("hotspot", "📡", "Hotspot", self.on_hotspot_toggle),
            ("location", "📍", "Location", self.on_location_toggle),
        ]
        
        row = 0
        col = 0
        for toggle_id, icon, label, callback in toggles:
            tile = self.create_toggle_tile(toggle_id, icon, label, callback)
            grid.attach(tile, col, row, 1, 1)
            col += 1
            if col > 1:
                col = 0
                row += 1
        
        # Brightness slider
        brightness_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        brightness_box.add_css_class('qs-slider-box')
        main_box.append(brightness_box)
        
        brightness_label = Gtk.Label(label="🔆 Brightness")
        brightness_label.add_css_class('qs-slider-label')
        brightness_box.append(brightness_label)
        
        brightness_scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL)
        brightness_scale.set_range(0, 100)
        brightness_scale.set_value(70)
        brightness_scale.set_draw_value(True)
        brightness_scale.connect('value-changed', self.on_brightness_changed)
        brightness_box.append(brightness_scale)
        
        # Volume slider
        volume_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        volume_box.add_css_class('qs-slider-box')
        main_box.append(volume_box)
        
        volume_label = Gtk.Label(label="🔊 Volume")
        volume_label.add_css_class('qs-slider-label')
        volume_box.append(volume_label)
        
        volume_scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL)
        volume_scale.set_range(0, 100)
        volume_scale.set_value(70)
        volume_scale.set_draw_value(True)
        volume_scale.connect('value-changed', self.on_volume_changed)
        volume_box.append(volume_scale)
        
        # Power profile selector
        profile_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        profile_box.set_margin_top(10)
        profile_box.set_margin_bottom(10)
        main_box.append(profile_box)
        
        profile_label = Gtk.Label(label="⚡ Power Profile")
        profile_label.add_css_class('qs-slider-label')
        profile_box.append(profile_label)
        
        profile_dropdown = Gtk.DropDown()
        profile_model = Gtk.StringList.new([
            "Balanced",
            "Performance", 
            "Power Saver"
        ])
        profile_dropdown.set_model(profile_model)
        profile_dropdown.set_selected(0)
        profile_dropdown.connect('notify::selected', self.on_profile_changed)
        profile_box.append(profile_dropdown)
        
        # Footer actions
        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        footer.add_css_class('qs-footer')
        footer.set_homogeneous(True)
        main_box.append(footer)
        
        settings_btn = Gtk.Button(label="⚙️ Settings")
        settings_btn.add_css_class('qs-action')
        settings_btn.connect('clicked', self.on_open_settings)
        footer.append(settings_btn)
        
        lock_btn = Gtk.Button(label="🔒 Lock")
        lock_btn.add_css_class('qs-action')
        lock_btn.connect('clicked', self.on_lock_screen)
        footer.append(lock_btn)
        
        power_btn = Gtk.Button(label="⏻ Power")
        power_btn.add_css_class('qs-action')
        power_btn.connect('clicked', self.on_power_menu)
        footer.append(power_btn)
    
    def create_toggle_tile(self, toggle_id, icon, label, callback):
        """Create a toggle tile button"""
        tile = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        tile.add_css_class('qs-tile')
        tile.toggle_id = toggle_id
        tile.active = False
        
        icon_label = Gtk.Label(label=icon)
        icon_label.add_css_class('qs-tile-icon')
        tile.append(icon_label)
        
        text_label = Gtk.Label(label=label)
        text_label.add_css_class('qs-tile-label')
        tile.append(text_label)
        
        # Click handler
        click = Gtk.GestureClick()
        click.connect('pressed', lambda g, n, x, y: callback(tile))
        tile.add_controller(click)
        
        return tile
    
    # Toggle callbacks
    def on_wifi_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
            subprocess.Popen(['nmcli', 'radio', 'wifi', 'on'])
        else:
            tile.remove_css_class('active')
            subprocess.Popen(['nmcli', 'radio', 'wifi', 'off'])
    
    def on_bluetooth_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
            subprocess.Popen(['bluetoothctl', 'power', 'on'])
        else:
            tile.remove_css_class('active')
            subprocess.Popen(['bluetoothctl', 'power', 'off'])
    
    def on_airplane_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
            subprocess.Popen(['nmcli', 'radio', 'all', 'off'])
        else:
            tile.remove_css_class('active')
            subprocess.Popen(['nmcli', 'radio', 'all', 'on'])
    
    def on_dnd_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
            subprocess.Popen(['makoctl', 'set-mode', 'do-not-disturb'])
        else:
            tile.remove_css_class('active')
            subprocess.Popen(['makoctl', 'set-mode', 'default'])
    
    def on_flashlight_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
            # Would need hardware control
            pass
        else:
            tile.remove_css_class('active')
    
    def on_rotation_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
        else:
            tile.remove_css_class('active')
    
    def on_hotspot_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
        else:
            tile.remove_css_class('active')
    
    def on_location_toggle(self, tile):
        tile.active = not tile.active
        if tile.active:
            tile.add_css_class('active')
        else:
            tile.remove_css_class('active')
    
    # Slider callbacks
    def on_brightness_changed(self, scale):
        value = int(scale.get_value())
        subprocess.Popen(['brightnessctl', 'set', f'{value}%'])
    
    def on_volume_changed(self, scale):
        value = int(scale.get_value())
        subprocess.Popen(['pactl', 'set-sink-volume', '@DEFAULT_SINK@', f'{value}%'])
    
    def on_profile_changed(self, dropdown, pspec):
        profiles = ['balanced', 'performance', 'powersave']
        selected = dropdown.get_selected()
        if 0 <= selected < len(profiles):
            subprocess.Popen(['phantom-power', profiles[selected]])
    
    # Footer callbacks
    def on_open_settings(self, button):
        subprocess.Popen(['phantom-settings'])
        self.close()
    
    def on_lock_screen(self, button):
        subprocess.Popen(['hyprlock'])
        self.close()
    
    def on_power_menu(self, button):
        subprocess.Popen(['wlogout'])
        self.close()


class PhantomQuickSettingsApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id='com.phantom.quicksettings')
        
    def do_activate(self):
        win = PhantomQuickSettings(application=self)
        win.present()


def main():
    app = PhantomQuickSettingsApp()
    return app.run(sys.argv)


if __name__ == '__main__':
    sys.exit(main())
