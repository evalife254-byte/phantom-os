    def create_power_page(self):
        """Create power settings page"""
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        page.set_margin_start(20)
        page.set_margin_end(20)
        
        # Header
        header = Gtk.Label(label="Power")
        header.set_markup("<big><b>🔋 Power</b></big>")
        header.set_margin_bottom(20)
        page.append(header)
        
        # Power profile group
        profile_group = self.create_settings_group("Power Profile")
        page.append(profile_group)
        
        # Profile selector
        profile_dropdown = Gtk.DropDown()
        profile_model = Gtk.StringList.new([
            "Balanced (Recommended)",
            "Performance",
            "Power Saver"
        ])
        profile_dropdown.set_model(profile_model)
        profile_dropdown.set_selected(0)
        profile_dropdown.connect('notify::selected', self.on_power_profile_changed)
        profile_row = self.create_setting_row(
            "Power Profile",
            "Optimize for performance or battery life",
            profile_dropdown
        )
        profile_group.append(profile_row)
        
