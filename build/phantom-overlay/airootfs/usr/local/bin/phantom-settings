#!/usr/bin/env python3
"""
Phantom Settings - System Settings Application for Phantom OS
A comprehensive settings manager with Ghost Protocol theme
"""

import gi
import os
import sys
import json
import subprocess
from pathlib import Path

gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, Gio, GLib, Gdk

class PhantomSettings(Adw.ApplicationWindow):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.set_title("Phantom Settings")
        self.set_default_size(1000, 700)
        
        self.settings_stack = None
        self.setup_ui()
        self.apply_css()
        
    def apply_css(self):
        """Apply Ghost Protocol theme"""
        css_provider = Gtk.CssProvider()
        css = """
        window {
            background-color: #0A0A0F;
            color: #E0E0E8;
        }
        
        .sidebar {
            background-color: #141420;
            border-right: 1px solid #1A1A2E;
        }
        
        .settings-category {
            padding: 12px 16px;
            border-radius: 8px;
            margin: 4px 8px;
            color: #E0E0E8;
        }
        
        .settings-category:hover {
            background-color: rgba(0, 240, 255, 0.1);
        }
        
        .settings-category.selected {
            background-color: rgba(0, 240, 255, 0.2);
            border-left: 3px solid #00F0FF;
        }
        
        .settings-page {
            background-color: #0A0A0F;
            padding: 20px;
        }
        
        .settings-group {
            background-color: #141420;
            border-radius: 12px;
            border: 1px solid #1A1A2E;
            margin: 12px 0;
        }
        
        .settings-row {
            padding: 16px;
            border-bottom: 1px solid #1A1A2E;
        }
        
        .settings-row:last-child {
            border-bottom: none;
        }
        
        .settings-title {
            color: #00F0FF;
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 4px;
        }
        
        .settings-description {
            color: #6B6B80;
            font-size: 12px;
        }
        
        button {
            background-color: #1A1A2E;
            color: #E0E0E8;
            border: 1px solid #00F0FF;
            border-radius: 6px;
            padding: 8px 16px;
        }
        
        button:hover {
            background-color: rgba(0, 240, 255, 0.15);
        }
        
        switch {
            background-color: #1A1A2E;
        }
        
        switch:checked {
            background-color: #00F0FF;
        }
        
        scale trough {
            background-color: #1A1A2E;
            border-radius: 4px;
        }
        
        scale highlight {
            background-color: #00F0FF;
            border-radius: 4px;
        }
        
        entry {
            background-color: #1A1A2E;
            color: #E0E0E8;
            border: 1px solid #00F0FF;
            border-radius: 6px;
            padding: 8px;
        }
        
        dropdown {
            background-color: #1A1A2E;
            color: #E0E0E8;
            border: 1px solid #00F0FF;
            border-radius: 6px;
        }
        """
        css_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
    
    def setup_ui(self):
        """Setup the main UI with sidebar and content area"""
        # Main horizontal box
        main_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.set_content(main_box)
        
        # Sidebar with categories
        sidebar = self.create_sidebar()
        sidebar.set_size_request(250, -1)
        sidebar.add_css_class('sidebar')
        main_box.append(sidebar)
        
        # Content area with stack
        self.settings_stack = Gtk.Stack()
        self.settings_stack.add_css_class('settings-page')
        self.settings_stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
        main_box.append(self.settings_stack)
        
        # Add settings pages
        self.settings_stack.add_child(self.create_appearance_page(), "appearance", "Appearance")
        self.settings_stack.add_child(self.create_display_page(), "display", "Display")
        self.settings_stack.add_child(self.create_network_page(), "network", "Network")
        self.settings_stack.add_child(self.create_power_page(), "power", "Power")
        self.settings_stack.add_child(self.create_sound_page(), "sound", "Sound")
        self.settings_stack.add_child(self.create_users_page(), "users", "Users")
        self.settings_stack.add_child(self.create_system_page(), "system", "System")
        
        # Show appearance page by default
        self.settings_stack.set_visible_child_name("appearance")
    
    def create_sidebar(self):
        """Create sidebar with settings categories"""
        sidebar_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        
        # Title
        title = Gtk.Label(label="⚙️ Settings")
        title.set_margin_top(20)
        title.set_margin_bottom(20)
        title.set_markup("<big><b>⚙️ Phantom Settings</b></big>")
        sidebar_box.append(title)
        
        # Categories list
        categories = [
            ("appearance", "🎨", "Appearance"),
            ("display", "🖥️", "Display"),
            ("network", "🌐", "Network"),
            ("power", "🔋", "Power"),
            ("sound", "🔊", "Sound"),
            ("users", "👤", "Users"),
            ("system", "⚡", "System"),
        ]
        
        for page_id, icon, label in categories:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.add_css_class('settings-category')
            row.page_id = page_id
            
            icon_label = Gtk.Label(label=icon)
            row.append(icon_label)
            
            text_label = Gtk.Label(label=label)
            text_label.set_xalign(0)
            text_label.set_hexpand(True)
            row.append(text_label)
            
            # Click handler
            click = Gtk.GestureClick()
            click.connect('pressed', lambda g, n, x, y, pid=page_id: self.on_category_clicked(pid))
            row.add_controller(click)
            
            sidebar_box.append(row)
            
            # Track first category as default selected
            if page_id == "appearance":
                row.add_css_class('selected')
                self.selected_category = row
        
        return sidebar_box
    
    def on_category_clicked(self, page_id):
        """Handle category selection"""
        # Update visual selection
        if hasattr(self, 'selected_category'):
            self.selected_category.remove_css_class('selected')
        
        # Find and highlight new selection
        sidebar = self.get_content().get_first_child()
        row = sidebar.get_first_child()
        while row:
            if isinstance(row, Gtk.Box) and hasattr(row, 'page_id'):
                if row.page_id == page_id:
                    row.add_css_class('selected')
                    self.selected_category = row
                    break
            row = row.get_next_sibling()
        
        # Switch page
        self.settings_stack.set_visible_child_name(page_id)
    
    def create_settings_group(self, title):
        """Create a settings group container"""
        group_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        group_box.add_css_class('settings-group')
        
        # Group title
        title_label = Gtk.Label(label=title)
        title_label.set_margin_top(12)
        title_label.set_margin_bottom(8)
        title_label.set_margin_start(16)
        title_label.set_markup(f"<b>{title}</b>")
        group_box.append(title_label)
        
        return group_box
    
    def create_setting_row(self, title, description, widget):
        """Create a settings row with title, description, and control"""
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        row.add_css_class('settings-row')
        
        # Text content
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        text_box.set_hexpand(True)
        row.append(text_box)
        
        title_label = Gtk.Label(label=title)
        title_label.add_css_class('settings-title')
        title_label.set_xalign(0)
        text_box.append(title_label)
        
        if description:
            desc_label = Gtk.Label(label=description)
            desc_label.add_css_class('settings-description')
            desc_label.set_xalign(0)
            text_box.append(desc_label)
        
        # Control widget
        row.append(widget)
        
        return row
    
    def create_appearance_page(self):
        """Create appearance settings page"""
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        page.set_margin_start(20)
        page.set_margin_end(20)
        
        # Header
        header = Gtk.Label(label="Appearance")
        header.set_markup("<big><b>🎨 Appearance</b></big>")
        header.set_margin_bottom(20)
        page.append(header)
        
        # Theme group
        theme_group = self.create_settings_group("Theme")
        page.append(theme_group)
        
        # Theme selector
        theme_dropdown = Gtk.DropDown()
        theme_model = Gtk.StringList.new([
            "Ghost Protocol (Default)",
            "Specter", 
            "Wraith",
            "Eclipse",
            "Daylight"
        ])
        theme_dropdown.set_model(theme_model)
        theme_dropdown.set_selected(0)
        theme_row = self.create_setting_row(
            "Color Theme",
            "Choose your preferred color scheme",
            theme_dropdown
        )
        theme_group.append(theme_row)
        
        # Dark mode toggle
        dark_switch = Gtk.Switch()
        dark_switch.set_active(True)
        dark_switch.set_valign(Gtk.Align.CENTER)
        dark_row = self.create_setting_row(
            "Dark Mode",
            "Use dark colors for the system interface",
            dark_switch
        )
        theme_group.append(dark_row)
        
        # Accent color selector
        accent_dropdown = Gtk.DropDown()
        accent_model = Gtk.StringList.new([
            "Cyan (Default)",
            "Purple",
            "Yellow",
            "Green",
            "Red"
        ])
        accent_dropdown.set_model(accent_model)
        accent_dropdown.set_selected(0)
        accent_row = self.create_setting_row(
            "Accent Color",
            "Primary accent color for highlights",
            accent_dropdown
        )
        theme_group.append(accent_row)
        
        # Wallpaper group
        wallpaper_group = self.create_settings_group("Wallpaper")
        page.append(wallpaper_group)
        
        # Current wallpaper preview
        wallpaper_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        wallpaper_box.set_margin_start(16)
        wallpaper_box.set_margin_end(16)
        wallpaper_box.set_margin_bottom(12)
        
        preview = Gtk.DrawingArea()
        preview.set_size_request(200, 120)
        preview.set_draw_func(self.draw_wallpaper_preview)
        wallpaper_box.append(preview)
        
        # Wallpaper buttons
        button_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        button_box.set_margin_start(16)
        button_box.set_valign(Gtk.Align.CENTER)
        wallpaper_box.append(button_box)
        
        change_btn = Gtk.Button(label="🖼️ Change Wallpaper")
        change_btn.connect('clicked', self.on_change_wallpaper)
        button_box.append(change_btn)
        
        random_btn = Gtk.Button(label="🎲 Random Wallpaper")
        random_btn.connect('clicked', self.on_random_wallpaper)
        button_box.append(random_btn)
        
        wallpaper_group.append(wallpaper_box)
        
        return page
    
