        username_label = Gtk.Label(label="Username: phantom-user")
        username_label.set_margin_start(16)
        username_label.set_margin_bottom(8)
        user_group.append(username_label)
        
        # Change password button
        passwd_btn = Gtk.Button(label="🔑 Change Password")
        passwd_btn.set_margin_start(16)
        passwd_btn.set_margin_end(16)
        passwd_btn.set_margin_bottom(12)
        user_group.append(passwd_btn)
        
