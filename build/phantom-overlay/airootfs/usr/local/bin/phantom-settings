    def create_system_page(self):
        """Create system settings page"""
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        page.set_margin_start(20)
        page.set_margin_end(20)
        
        # Header
        header = Gtk.Label(label="System")
        header.set_markup("<big><b>⚡ System</b></big>")
        header.set_margin_bottom(20)
        page.append(header)
        
        # About group
        about_group = self.create_settings_group("About")
        page.append(about_group)
        
        # OS info
        os_info = Gtk.Label(label="Phantom OS v0.1.0 (Ghost Protocol)")
        os_info.set_margin_start(16)
        os_info.set_margin_top(8)
        about_group.append(os_info)
        
        kernel_info = Gtk.Label(label="Kernel: Linux (rolling)")
        kernel_info.set_margin_start(16)
        kernel_info.set_margin_bottom(12)
        about_group.append(kernel_info)
        
        # Updates group
        updates_group = self.create_settings_group("Updates")
        page.append(updates_group)
        
        # Auto updates toggle
        updates_switch = Gtk.Switch()
        updates_switch.set_active(True)
        updates_switch.set_valign(Gtk.Align.CENTER)
        updates_row = self.create_setting_row(
            "Automatic Updates",
            "Keep system up to date automatically",
            updates_switch
        )
        updates_group.append(updates_row)
        
        # Check updates button
        check_btn = Gtk.Button(label="🔄 Check for Updates")
        check_btn.set_margin_start(16)
        check_btn.set_margin_end(16)
        check_btn.set_margin_bottom(12)
        updates_group.append(check_btn)
        
        return page
    
    # Event handlers
    def draw_wallpaper_preview(self, area, ctx, width, height):
        """Draw wallpaper preview"""
        ctx.set_source_rgb(0.04, 0.04, 0.06)
        ctx.rectangle(0, 0, width, height)
        ctx.fill()
        
        ctx.set_source_rgb(0, 0.94, 1)
        ctx.set_line_width(2)
        ctx.rectangle(1, 1, width-2, height-2)
        ctx.stroke()
        
        ctx.set_source_rgb(0, 0.94, 1)
        ctx.select_font_face("Sans", 0, 400)
        ctx.set_font_size(16)
        ctx.move_to(width/2 - 40, height/2)
        ctx.show_text("🖼️ Wallpaper")
    
    def on_change_wallpaper(self, button):
        """Open wallpaper changer"""
        subprocess.Popen(['phantom-wallpaper', 'random'])
    
    def on_random_wallpaper(self, button):
        """Set random wallpaper"""
        subprocess.Popen(['phantom-wallpaper', 'random'])
    
    def on_view_networks(self, button):
        """View available networks"""
        subprocess.Popen(['nmcli', 'device', 'wifi', 'list'])
    
    def on_power_profile_changed(self, dropdown, pspec):
        """Handle power profile change"""
        profiles = ['balanced', 'performance', 'powersave']
        selected = dropdown.get_selected()
        if 0 <= selected < len(profiles):
            subprocess.Popen(['phantom-power', profiles[selected]])


class PhantomSettingsApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id='com.phantom.settings')
        
    def do_activate(self):
        win = PhantomSettings(application=self)
        win.present()


def main():
    app = PhantomSettingsApp()
    return app.run(sys.argv)


if __name__ == '__main__':
    sys.exit(main())
