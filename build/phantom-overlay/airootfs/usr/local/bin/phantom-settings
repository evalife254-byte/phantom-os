            "Never"
        ])
        timeout_dropdown.set_model(timeout_model)
        timeout_dropdown.set_selected(1)
        timeout_row = self.create_setting_row(
            "Screen Blank",
            "Turn off screen after inactivity",
            timeout_dropdown
        )
        screen_group.append(timeout_row)
        
        # Battery group
        battery_group = self.create_settings_group("Battery")
        page.append(battery_group)
        
        # Show battery percentage
