#!/usr/bin/env python3
"""
Phantom OS Theme Editor v2
Enhanced GUI for customizing Phantom themes with live preview
"""

import json
import os
import sys
import subprocess
from pathlib import Path

try:
    import gi
    gi.require_version('Gtk', '3.0')
    from gi.repository import Gtk, Gdk, GObject
except ImportError:
    print("Error: GTK3 not available. Install python-gobject", file=sys.stderr)
    sys.exit(1)


class PhantomThemeEditor(Gtk.Window):
    def __init__(self):
        super().__init__(title="Phantom Theme Editor v2")
        self.set_default_size(800, 600)
        self.set_border_width(20)
        
        config_home = os.environ.get('XDG_CONFIG_HOME', os.path.expanduser('~/.config'))
        self.theme_file = Path(config_home) / 'phantom' / 'theme.json'
        self.presets_dir = Path('/usr/share/phantom/themes')
        
        self.theme_data = self.load_theme()
        self.color_buttons = {}
        
        self.setup_ui()
        self.apply_phantom_styling()
        
    def apply_phantom_styling(self):
        """Apply Ghost Protocol styling to the editor"""
        css = """
        window {
            background-color: #0A0A0F;
        }
        
        .title-label {
            color: #00F0FF;
            font-size: 18px;
            font-weight: bold;
        }
        
        .section-label {
            color: #7B68EE;
            font-size: 14px;
            font-weight: bold;
            margin-top: 12px;
        }
        
        button {
            background-color: #1A1A2E;
            color: #E0E0E8;
            border: 1px solid #00F0FF;
            border-radius: 6px;
            padding: 8px 16px;
        }
        
        button:hover {
            background-color: rgba(0, 240, 255, 0.15);
        }
        
        button.suggested-action {
            background-color: rgba(0, 240, 255, 0.2);
        }
        
        entry {
            background-color: #141420;
            color: #E0E0E8;
            border: 1px solid #1A1A2E;
            border-radius: 4px;
        }
        
        combobox {
            background-color: #141420;
            color: #E0E0E8;
        }
        
        .preview-box {
            background-color: #141420;
            border: 1px solid #00F0FF;
            border-radius: 8px;
            padding: 12px;
        }
        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
        
    def load_theme(self):
        """Load current theme from file"""
        if not self.theme_file.exists():
            return self.get_default_theme()
        
        try:
            with open(self.theme_file, 'r') as f:
                return json.load(f)
        except Exception as e:
            print(f"Error loading theme: {e}", file=sys.stderr)
            return self.get_default_theme()
    
    def get_default_theme(self):
        """Return default Ghost Protocol theme"""
        return {
            "name": "custom",
            "display_name": "Custom Theme",
            "description": "User customized theme",
            "colors": {
                "background": "#0A0A0F",
                "surface": "#141420",
                "panel": "#1A1A2E",
                "accent_primary": "#00F0FF",
                "accent_secondary": "#7B68EE",
                "text_primary": "#E0E0E8",
                "text_secondary": "#6B6B80",
                "warning": "#FFD93D",
                "critical": "#FF6B6B",
                "success": "#6BCF7F"
            }
        }
    
    def load_preset(self, preset_name):
        """Load a preset theme"""
        preset_file = self.presets_dir / f"{preset_name}.json"
        if preset_file.exists():
            try:
                with open(preset_file) as f:
                    preset_data = json.load(f)
                    # Update current theme with preset colors
                    self.theme_data['colors'] = preset_data.get('colors', self.theme_data['colors'])
                    self.theme_data['display_name'] = f"Custom ({preset_data.get('display_name', preset_name)})"
                    self.refresh_color_buttons()
                    return True
            except Exception as e:
                print(f"Error loading preset: {e}", file=sys.stderr)
        return False
    
    def refresh_color_buttons(self):
        """Refresh color buttons with current theme data"""
        colors = self.theme_data.get('colors', {})
        for key, color_button in self.color_buttons.items():
            color_value = colors.get(key, '#000000')
            rgba = Gdk.RGBA()
            rgba.parse(color_value)
            color_button.set_rgba(rgba)
    
    def setup_ui(self):
        """Build the UI"""
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.add(vbox)
        
        # Header
        header = Gtk.Label()
        header.set_markup("<big><b>Phantom Theme Editor</b></big>")
        vbox.pack_start(header, False, False, 0)
        
        # Theme name
        name_box = Gtk.Box(spacing=10)
        name_box.pack_start(Gtk.Label(label="Theme Name:"), False, False, 0)
        self.name_entry = Gtk.Entry()
        self.name_entry.set_text(self.theme_data.get('display_name', 'Custom Theme'))
        name_box.pack_start(self.name_entry, True, True, 0)
        vbox.pack_start(name_box, False, False, 0)
        
        # Preset selector
        preset_box = Gtk.Box(spacing=10)
        preset_box.pack_start(Gtk.Label(label="Load Preset:"), False, False, 0)
        
        preset_combo = Gtk.ComboBoxText()
        presets = ['ghost-protocol', 'specter', 'wraith', 'eclipse', 'daylight']
        for preset in presets:
            preset_combo.append_text(preset.replace('-', ' ').title())
        preset_combo.set_active(0)
        preset_box.pack_start(preset_combo, True, True, 0)
        
        load_preset_btn = Gtk.Button(label="Load")
        load_preset_btn.connect("clicked", lambda w: self.load_preset(presets[preset_combo.get_active()]))
        preset_box.pack_start(load_preset_btn, False, False, 0)
        
        vbox.pack_start(preset_box, False, False, 0)
        
        # Separator
        vbox.pack_start(Gtk.Separator(), False, False, 5)
        
        # Live preview checkbox
        self.live_preview = Gtk.CheckButton(label="Live Preview")
        self.live_preview.set_active(True)
        vbox.pack_start(self.live_preview, False, False, 0)
        
        # Color pickers
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        
        colors_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        scroll.add(colors_box)
        
        self.color_buttons = {}
        colors = self.theme_data.get('colors', {})
        
        color_labels = {
            'background': 'Background',
            'surface': 'Surface',
            'panel': 'Panel',
            'accent_primary': 'Accent Primary',
            'accent_secondary': 'Accent Secondary',
            'text_primary': 'Text Primary',
            'text_secondary': 'Text Secondary',
            'warning': 'Warning',
            'critical': 'Critical',
            'success': 'Success'
        }
        
        for key, label in color_labels.items():
            color_value = colors.get(key, '#000000')
            row = self.create_color_row(label, key, color_value)
            colors_box.pack_start(row, False, False, 0)
        
        vbox.pack_start(scroll, True, True, 0)
        
        # Buttons
        button_box = Gtk.Box(spacing=10)
        button_box.set_halign(Gtk.Align.END)
        
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda w: self.destroy())
        button_box.pack_start(cancel_btn, False, False, 0)
        
        apply_btn = Gtk.Button(label="Apply")
        apply_btn.get_style_context().add_class('suggested-action')
        apply_btn.connect("clicked", self.on_apply)
        button_box.pack_start(apply_btn, False, False, 0)
        
        vbox.pack_start(button_box, False, False, 0)
    
    def create_color_row(self, label, key, color_value):
        """Create a row with label and color picker"""
        row = Gtk.Box(spacing=10)
        
        label_widget = Gtk.Label(label=label)
        label_widget.set_width_chars(20)
        label_widget.set_xalign(0)
        row.pack_start(label_widget, False, False, 0)
        
        color_button = Gtk.ColorButton()
        rgba = Gdk.RGBA()
        rgba.parse(color_value)
        color_button.set_rgba(rgba)
        color_button.set_use_alpha(False)
        self.color_buttons[key] = color_button
        row.pack_start(color_button, False, False, 0)
        
        # Hex entry
        hex_entry = Gtk.Entry()
        hex_entry.set_text(color_value)
        hex_entry.set_width_chars(10)
        hex_entry.connect("changed", self.on_hex_changed, color_button)
        color_button.connect("color-set", self.on_color_set, hex_entry)
        row.pack_start(hex_entry, False, False, 0)
        
        return row
    
    def on_hex_changed(self, entry, color_button):
        """Update color button when hex entry changes"""
        hex_value = entry.get_text()
        if hex_value.startswith('#') and len(hex_value) == 7:
            rgba = Gdk.RGBA()
            if rgba.parse(hex_value):
                color_button.set_rgba(rgba)
    
    def on_color_set(self, color_button, hex_entry):
        """Update hex entry when color button changes"""
        rgba = color_button.get_rgba()
        hex_value = "#{:02x}{:02x}{:02x}".format(
            int(rgba.red * 255),
            int(rgba.green * 255),
            int(rgba.blue * 255)
        ).upper()
        hex_entry.set_text(hex_value)
    
    def on_apply(self, button):
        """Save theme and apply"""
        # Update theme data
        self.theme_data['display_name'] = self.name_entry.get_text()
        self.theme_data['name'] = self.name_entry.get_text().lower().replace(' ', '-')
        
        for key, color_button in self.color_buttons.items():
            rgba = color_button.get_rgba()
            hex_value = "#{:02x}{:02x}{:02x}".format(
                int(rgba.red * 255),
                int(rgba.green * 255),
                int(rgba.blue * 255)
            ).upper()
            self.theme_data['colors'][key] = hex_value
        
        # Save to file
        try:
            self.theme_file.parent.mkdir(parents=True, exist_ok=True)
            with open(self.theme_file, 'w') as f:
                json.dump(self.theme_data, f, indent=2)
            
            # Reload theme
            os.system('phantom-theme reload')
            
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.INFO,
                buttons=Gtk.ButtonsType.OK,
                text="Theme Applied"
            )
            dialog.format_secondary_text("Your custom theme has been saved and applied.")
            dialog.run()
            dialog.destroy()
            
            self.destroy()
            
        except Exception as e:
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text="Error Saving Theme"
            )
            dialog.format_secondary_text(str(e))
            dialog.run()
            dialog.destroy()


def main():
    win = PhantomThemeEditor()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == '__main__':
    main()
