#!/usr/bin/env python3
"""
PHM Package Manager - Phantom OS Custom Package Format
.phm package format with CLI tool for install/remove/update/search
"""

import json
import os
import sys
import shutil
import tarfile
import hashlib
import argparse
from pathlib import Path
from datetime import datetime

PHM_VERSION = "1.0.0"
PHM_EXTENSION = ".phm"
PHM_DB_DIR = Path("/var/lib/phm")
PHM_CACHE_DIR = Path("/var/cache/phm")
PHM_CONFIG_DIR = Path("/etc/phm")
PHM_REPOS_FILE = PHM_CONFIG_DIR / "repositories.json"

class PHMPackage:
    """Represents a .phm package"""
    
    def __init__(self, filepath=None):
        self.filepath = filepath
        self.metadata = {}
        self.files = []
        
        if filepath and Path(filepath).exists():
            self.load_package()
    
    def load_package(self):
        """Load package metadata from .phm file"""
        if not tarfile.is_tarfile(self.filepath):
            raise ValueError(f"Invalid .phm package: {self.filepath}")
        
        with tarfile.open(self.filepath, "r:gz") as tar:
            # Extract metadata
            metadata_member = tar.getmember("package.json")
            metadata_file = tar.extractfile(metadata_member)
            self.metadata = json.loads(metadata_file.read().decode())
            
            # List all files
            self.files = [m.name for m in tar.getmembers() if m.isfile()]
    
    def validate(self):
        """Validate package structure and checksums"""
        required_fields = ["name", "version", "architecture", "maintainer"]
        
        for field in required_fields:
            if field not in self.metadata:
                return False, f"Missing required field: {field}"
        
        return True, "Valid package"


class PHMManager:
    """Main package manager class"""
    
    def __init__(self):
        self.installed_db = PHM_DB_DIR / "installed.json"
        self.repos_file = PHM_REPOS_FILE
        self.ensure_directories()
        self.load_installed()
    
    def ensure_directories(self):
        """Ensure required directories exist"""
        PHM_DB_DIR.mkdir(parents=True, exist_ok=True)
        PHM_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        PHM_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    
    def load_installed(self):
        """Load installed packages database"""
        if self.installed_db.exists():
            with open(self.installed_db) as f:
                self.installed = json.load(f)
        else:
            self.installed = {}
    
    def save_installed(self):
        """Save installed packages database"""
        with open(self.installed_db, "w") as f:
            json.dump(self.installed, f, indent=2)
    
    def install_package(self, package_path, force=False):
        """Install a .phm package"""
        package_path = Path(package_path)
        
        if not package_path.exists():
            print(f"Error: Package not found: {package_path}")
            return False
        
        if not package_path.suffix == PHM_EXTENSION:
            print(f"Error: Invalid package format (must be {PHM_EXTENSION})")
            return False
        
        # Load and validate package
        try:
            package = PHMPackage(package_path)
            valid, message = package.validate()
            if not valid:
                print(f"Error: Invalid package - {message}")
                return False
        except Exception as e:
            print(f"Error loading package: {e}")
            return False
        
        name = package.metadata["name"]
        version = package.metadata["version"]
        
        # Check if already installed
        if name in self.installed and not force:
            installed_version = self.installed[name]["version"]
            print(f"Package '{name}' is already installed (version {installed_version})")
            print("Use --force to reinstall")
            return False
        
        print(f"Installing {name} v{version}...")
        
        # Extract package
        extract_dir = PHM_CACHE_DIR / f"{name}-{version}"
        if extract_dir.exists():
            shutil.rmtree(extract_dir)
        extract_dir.mkdir(parents=True)
        
        try:
            with tarfile.open(package_path, "r:gz") as tar:
                tar.extractall(extract_dir)
        except Exception as e:
            print(f"Error extracting package: {e}")
            return False
        
        # Run pre-install script
        pre_install = extract_dir / "scripts" / "pre-install.sh"
        if pre_install.exists():
            print("Running pre-install script...")
            result = os.system(f"bash {pre_install}")
            if result != 0:
                print("Error: Pre-install script failed")
                return False
        
        # Install files
        install_root = Path(package.metadata.get("install_root", "/"))
        files_to_install = package.metadata.get("files", [])
        installed_files = []
        
        for file_info in files_to_install:
            src = extract_dir / "files" / file_info["source"]
            dst = install_root / file_info["destination"]
            
            if src.exists():
                dst.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, dst)
                installed_files.append(str(dst))
                print(f"  Installed: {dst}")
        
        # Run post-install script
        post_install = extract_dir / "scripts" / "post-install.sh"
        if post_install.exists():
            print("Running post-install script...")
            os.system(f"bash {post_install}")
        
        # Update database
        self.installed[name] = {
            "version": version,
            "install_date": datetime.now().isoformat(),
            "files": installed_files,
            "metadata": package.metadata
        }
        self.save_installed()
        
        # Cleanup
        shutil.rmtree(extract_dir)
        
        print(f"Successfully installed {name} v{version}")
        return True
    
    def remove_package(self, name):
        """Remove an installed package"""
        if name not in self.installed:
            print(f"Error: Package '{name}' is not installed")
            return False
        
        package_info = self.installed[name]
        version = package_info["version"]
        
        print(f"Removing {name} v{version}...")
        
        # Remove installed files
        for file_path in reversed(package_info["files"]):
            path = Path(file_path)
            if path.exists():
                if path.is_file():
                    path.unlink()
                    print(f"  Removed: {path}")
                elif path.is_dir() and not any(path.iterdir()):
                    path.rmdir()
        
        # Run pre-remove script if available
        pre_remove = Path(f"/var/lib/phm/scripts/{name}-pre-remove.sh")
        if pre_remove.exists():
            print("Running pre-remove script...")
            os.system(f"bash {pre_remove}")
        
        # Update database
        del self.installed[name]
        self.save_installed()
        
        print(f"Successfully removed {name}")
        return True
    
    def list_installed(self):
        """List all installed packages"""
        if not self.installed:
            print("No packages installed")
            return
        
        print(f"{'Package Name':<30} {'Version':<15} {'Install Date'}")
        print("-" * 65)
        
        for name, info in sorted(self.installed.items()):
            version = info["version"]
            date = info["install_date"][:10]  # Just the date part
            print(f"{name:<30} {version:<15} {date}")
    
    def search_packages(self, query):
        """Search for packages (placeholder for repository search)"""
        print(f"Searching for '{query}'...")
        print("(Repository search not yet implemented)")
        
        # Search in installed packages
        matches = []
        for name, info in self.installed.items():
            if query.lower() in name.lower():
                matches.append((name, info))
        
        if matches:
            print(f"\nInstalled packages matching '{query}':")
            for name, info in matches:
                print(f"  {name} v{info['version']}")
        else:
            print(f"No installed packages match '{query}'")
    
    def show_package_info(self, name):
        """Show detailed package information"""
        if name not in self.installed:
            print(f"Error: Package '{name}' is not installed")
            return
        
        info = self.installed[name]
        meta = info["metadata"]
        
        print(f"Package: {name}")
        print(f"Version: {info['version']}")
        print(f"Installed: {info['install_date']}")
        print(f"Description: {meta.get('description', 'N/A')}")
        print(f"Maintainer: {meta.get('maintainer', 'N/A')}")
        print(f"Architecture: {meta.get('architecture', 'N/A')}")
        print(f"Files installed: {len(info['files'])}")
    
    def create_package(self, source_dir, output_dir=None):
        """Create a .phm package from a source directory"""
        source_dir = Path(source_dir)
        
        if not source_dir.exists():
            print(f"Error: Source directory not found: {source_dir}")
            return False
        
        # Load package.json
        package_json = source_dir / "package.json"
        if not package_json.exists():
            print("Error: package.json not found in source directory")
            return False
        
        with open(package_json) as f:
            metadata = json.load(f)
        
        name = metadata["name"]
        version = metadata["version"]
        
        # Determine output path
        if output_dir:
            output_path = Path(output_dir) / f"{name}-{version}{PHM_EXTENSION}"
        else:
            output_path = Path(f"{name}-{version}{PHM_EXTENSION}")
        
        print(f"Creating package: {output_path}")
        
        # Create tar.gz archive
        with tarfile.open(output_path, "w:gz") as tar:
            # Add all files from source directory
            for item in source_dir.rglob("*"):
                arcname = item.relative_to(source_dir)
                tar.add(item, arcname)
        
        print(f"Package created: {output_path}")
        return True


def main():
    parser = argparse.ArgumentParser(
        description="PHM Package Manager - Phantom OS Package Manager",
        prog="phm"
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Available commands")
    
    # Install command
    install_parser = subparsers.add_parser("install", help="Install a .phm package")
    install_parser.add_argument("package", help="Path to .phm package file")
    install_parser.add_argument("--force", "-f", action="store_true", help="Force reinstall")
    
    # Remove command
    remove_parser = subparsers.add_parser("remove", help="Remove an installed package")
    remove_parser.add_argument("name", help="Package name to remove")
    
    # List command
    list_parser = subparsers.add_parser("list", help="List installed packages")
    
    # Search command
    search_parser = subparsers.add_parser("search", help="Search for packages")
    search_parser.add_argument("query", help="Search query")
    
    # Info command
    info_parser = subparsers.add_parser("info", help="Show package information")
    info_parser.add_argument("name", help="Package name")
    
    # Create command
    create_parser = subparsers.add_parser("create", help="Create a .phm package")
    create_parser.add_argument("source", help="Source directory containing package.json")
    create_parser.add_argument("--output", "-o", help="Output directory for .phm file")
    
    # Version command
    version_parser = subparsers.add_parser("version", help="Show PHM version")
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    manager = PHMManager()
    
    if args.command == "install":
        success = manager.install_package(args.package, args.force)
        return 0 if success else 1
    
    elif args.command == "remove":
        success = manager.remove_package(args.name)
        return 0 if success else 1
    
    elif args.command == "list":
        manager.list_installed()
        return 0
    
    elif args.command == "search":
        manager.search_packages(args.query)
        return 0
    
    elif args.command == "info":
        manager.show_package_info(args.name)
        return 0
    
    elif args.command == "create":
        success = manager.create_package(args.source, args.output)
        return 0 if success else 1
    
    elif args.command == "version":
        print(f"PHM Package Manager v{PHM_VERSION}")
        print("Phantom OS Package Format (.phm)")
        return 0
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
